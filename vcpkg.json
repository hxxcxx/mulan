{
  "name": "mulan",
  "version": "1.0.0",
  "builtin-baseline": "616affa24b974b710a4fc26257e90b7fda6d6826",
  "features": {
    "linux-desktop": {
      "description": "Linux X11/XCB Qt platform dependencies",
      "supports": "linux",
      "dependencies": [
        {
          "name": "vulkan-loader",
          "default-features": false,
          "features": ["xcb"]
        },
        {
          "name": "qtbase",
          "default-features": false,
          "features": ["fontconfig", "freetype", "xcb"]
        }
      ]
    },
    "tracy-profiler": {
      "description": "Temporary Tracy backend for timeline and lock-contention investigations",
      "dependencies": [
        {
          "name": "tracy",
          "default-features": false
        }
      ]
    },
    "windows-qt-deploy": {
      "description": "Qt deployment tool used by Windows development and packaging targets",
      "supports": "windows",
      "dependencies": [
        {
          "name": "qtbase",
          "default-features": false,
          "features": ["windeployqt"]
        }
      ]
    }
  },
  "dependencies": [
    "vulkan",
    "vulkan-memory-allocator",
    {
      "name": "xcb",
      "platform": "linux"
    },
    {
      "name": "glad",
      "platform": "windows"
    },
    "stb",
    "nlohmann-json",
    "fastgltf",
    "mikktspace",
    "assimp",
    {
      "name": "spdlog",
      "default-features": false
    },
    {
      "name": "freetype",
      "default-features": false
    },
    "tomlplusplus",
    "gtest",
    "shader-slang",
    {
      "name": "qtbase",
      "default-features": false,
      "features": ["gui", "widgets", "png"]
    },
    "qtsvg",
    {
      "name": "glslang",
      "features": ["tools"],
      "platform": "windows"
    }
  ]
}
