BasedOnStyle: Google
Language: Cpp
Standard: Latest

# 缩进
IndentWidth: 4
TabWidth: 4
UseTab: Never
AccessModifierOffset: -4

# 大括号：全部不换行（与 image.h 现有风格一致）
BreakBeforeBraces: Attach
BraceWrapping:
  AfterFunction: false
  AfterClass: false
  AfterStruct: false
  AfterEnum: false
  AfterNamespace: false
  AfterControlStatement: Never
  BeforeElse: false

# 列宽
ColumnLimit: 120

# 指针/引用
PointerAlignment: Left
ReferenceAlignment: Left

# 空格
SpaceAfterCStyleCast: true
SpaceBeforeParens: ControlStatements

# 注释
ReflowComments: false

# 对齐：类型与变量名纵向对齐，但 = 赋值不对齐
AlignAfterOpenBracket: Align
AlignConsecutiveAssignments: None           # = 不对齐
AlignConsecutiveDeclarations: None            # 不对齐类型/变量名（避免 int    w 这种多空格）
AlignConsecutiveMacros: Consecutive
AlignEscapedNewlines: Left
AlignOperands: Align
AlignTrailingComments:
  Kind: Always
  OverEmptyLines: 1

# include 排序：只分组，不重排组内顺序
# - 项目内 "" 一组在前、系统 <> 一组在后（IncludeBlocks: Regroup）
# - 组内保持原始顺序，不按字母重排（SortIncludes: Never）
#   scalar/scalar.h、scalar/tolerance.h 等同目录文件的顺序由依赖关系决定，字母序无意义
SortIncludes: Never
IncludeBlocks: Regroup
IncludeCategories:
  - Regex: '^".*"'
    Priority: 1
  - Regex: '^<.*>'
    Priority: 2

# 其他
AllowShortFunctionsOnASingleLine: InlineOnly      # 类内 inline 单行保留，顶层空函数体保留
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false
AllowShortCaseLabelsOnASingleLine: true           # case X: return 1; 保留单行
AllowShortBlocksOnASingleLine: Empty
AllowShortLambdasOnASingleLine: Inline

# switch/case 风格
IndentCaseLabels: false                            # case 不缩进，与 switch 对齐
AlwaysBreakTemplateDeclarations: true
ConstructorInitializerIndentWidth: 4
ContinuationIndentWidth: 8
Cpp11BracedListStyle: false
DerivePointerAlignment: false
FixNamespaceComments: true
NamespaceIndentation: None
SpacesInLineCommentPrefix:
  Minimum: 1
  Maximum: 1

# 尾随空格/换行
KeepEmptyLinesAtTheStartOfBlocks: false
MaxEmptyLinesToKeep: 1
