{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 24, "patch": 0 },
    "configurePresets": [
        {
            "name": "msvc",
            "displayName": "MSVC x64",
            "generator": "Visual Studio 18 2026",
            "architecture": "x64",
            "binaryDir": "${sourceDir}/build/msvc",
            "toolchainFile": "$penv{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
            "cacheVariables": {
                "MULAN_PROFILER_BACKEND": "builtin",
                "VCPKG_OVERLAY_PORTS": "${sourceDir}/cmake/vcpkg-overlay-ports",
                "OCCT_ROOT": {
                    "type": "PATH",
                    "value": "$penv{OCCT_ROOT}"
                },
                "OCCT_3RDPARTY_DIR": {
                    "type": "PATH",
                    "value": "$penv{OCCT_3RDPARTY_DIR}"
                }
            }
        },
        {
            "name": "msvc-tracy",
            "displayName": "MSVC x64 + Tracy (temporary diagnostics)",
            "inherits": "msvc",
            "binaryDir": "${sourceDir}/build/msvc-tracy",
            "cacheVariables": {
                "MULAN_PROFILER_BACKEND": "tracy",
                "VCPKG_MANIFEST_FEATURES": "tracy-profiler"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "release",
            "configurePreset": "msvc",
            "configuration": "Release"
        },
        {
            "name": "relwithdebinfo",
            "configurePreset": "msvc",
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "relwithdebinfo-tracy",
            "configurePreset": "msvc-tracy",
            "configuration": "RelWithDebInfo"
        }
    ]
}
