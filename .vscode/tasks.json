{
    "version": "2.0.0",
    "options": {
        "cwd": "${workspaceFolder}"
    },
    "tasks": [
        {
            "label": "CMake: Configure",
            "type": "shell",
            "command": "cmake --preset msvc",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: Build (Release)",
            "type": "shell",
            "command": "cmake --build --preset release",
            "group": "build",
            "dependsOn": "CMake: Configure",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "CMake: Build (RelWithDebInfo)",
            "type": "shell",
            "command": "cmake --build --preset relwithdebinfo",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": "CMake: Configure",
            "problemMatcher": "$msCompile"
        },
        {
            "label": "CMake: Deploy (RelWithDebInfo)",
            "type": "shell",
            "command": "cmake --build build/msvc --config RelWithDebInfo --target mulan_deploy_runtime --parallel",
            "group": "build",
            "dependsOn": "CMake: Configure",
            "problemMatcher": "$msCompile"
        }
    ]
}
